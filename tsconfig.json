{
    "compilerOptions": {
        "target": "ES2021",
        "lib": ["ES2021"],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "declaration": true,
        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "isolatedModules": true,
        "verbatimModuleSyntax": false,
        "noEmit": true
    },
    "include": ["src", "test"]
}
